# ─── NutriPro Environment Variables ─────────────────────────────
# Copy this file to .env.local for local development

# ─── Next.js App ──────────────────────────────────────────────
# URL of your Cloudflare Worker (local or deployed)
NEXT_PUBLIC_WORKER_URL=http://localhost:8787

# JWT Secret — must match worker secret (min 32 chars)
JWT_SECRET=change-me-to-a-very-long-random-secret-min-32-chars

# ─── Cloudflare Worker (set via wrangler secret) ──────────────
# IMPORTANT: These are SECRETS, never committed to git.
# Set them with: wrangler secret put SECRET_NAME

# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# JWT_SECRET=your-32-char-minimum-secret

# ─── D1 Database (for drizzle-kit migrations) ─────────────────
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_DATABASE_ID=your-d1-database-id
# CLOUDFLARE_D1_TOKEN=your-api-token-with-d1-access

# ─── Local Development ────────────────────────────────────────
# Run worker: cd apps/worker && npx wrangler dev --local
# Run web:    cd apps/web && npm run dev
# Both run together: npm run dev (from root with turbo)
